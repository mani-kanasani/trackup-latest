# OPTIONAL. Supabase project credentials (Dashboard → Project Settings → API).
# You can leave these unset and connect to Supabase from the in-app setup screen
# instead. Set them only to pre-connect a project at build time (e.g. local dev).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: AI provider keys are NOT configured here.
# Each user adds their own key (Google Gemini / OpenAI / Anthropic) inside the
# app under Settings → AI Provider. The key is stored in the browser only.
