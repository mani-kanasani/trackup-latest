# Supabase project credentials (Dashboard → Project Settings → API).
#
# - Local dev: copy this to `.env` and fill these in.
# - Deploying for OTHER people: set these as environment variables on your host
#   (e.g. Netlify → Site configuration → Environment variables) so every visitor
#   connects automatically. Otherwise each visitor connects via the in-app wizard
#   (stored in their browser only).
#
# Use the PUBLISHABLE key (sb_publishable_…) for newer projects — the Edge
# Functions reject the legacy anon key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key

# NOTE: AI provider keys are NOT configured here.
# Each user adds their own key (Google Gemini / OpenAI / Anthropic) inside the
# app under Settings → AI Provider. The key is stored in the browser only.
